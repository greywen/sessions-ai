# Server address
SERVER_URL=http://localhost:3000

# Log level (trace/debug/info/warn/error)
LOG_LEVEL=info

# Heartbeat interval (seconds)
HEARTBEAT_INTERVAL_SECS=60

# Batch reporting parameters
BATCH_SIZE=50
BATCH_TIMEOUT_SECS=5

# Agent data directory (default: user data directory for Win/macOS/Linux)
# AGENT_DATA_DIR=

# Only collect these tools (comma-separated), empty means collect all supported tools
# COLLECT_TOOLS=OpenCode

# Registration polling: maximum number of polls (every 10 seconds)

REGISTER_MAX_POLLS=360
