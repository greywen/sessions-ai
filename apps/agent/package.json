{
  "name": "@session-vault/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run scripts/service/supervisor.ts",
    "start:once": "bun run src/main.ts",
    "build": "bun build src/main.ts --target=bun --outdir=dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "service:install": "bun run scripts/service/install.ts",
    "service:uninstall": "bun run scripts/service/uninstall.ts",
    "service:print": "bun run scripts/service/install.ts --print",
    "cache:clear": "bun run scripts/clear-cache.ts"
  },
  "dependencies": {
    "@session-vault/shared": "workspace:*",
    "chokidar": "^4.0.3",
    "node-machine-id": "^1.1.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3"
  }
}
