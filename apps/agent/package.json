{
  "name": "@sessions-ai/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/cli.ts start",
    "start:once": "bun run src/cli.ts run",
    "build": "bun build src/cli.ts --target=bun --outdir=dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "service:install": "bun run src/cli.ts service install",
    "service:uninstall": "bun run src/cli.ts service uninstall",
    "service:print": "bun run src/cli.ts service print",
    "cache:clear": "bun run src/cli.ts cache clear",
    "publish:prepare": "bun run scripts/build-publish.ts"
  },
  "dependencies": {
    "@sessions-ai/shared": "workspace:*",
    "chokidar": "^4.0.3",
    "node-machine-id": "^1.1.12",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3"
  }
}
