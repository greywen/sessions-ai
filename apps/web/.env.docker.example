# Copy to apps/web/.env.docker and customize for `docker compose up`.
# Nothing here is read at build-time — values are injected into the running
# `web` container via docker-compose.yml.

POSTGRES_USER=sessions
POSTGRES_PASSWORD=12345678
POSTGRES_DB=sessions_ai
# PostgreSQL is internal-only in docker-compose (no host port published).

WEB_PORT=23712
JWT_SECRET=please-change-me-32-chars-minimum

ADMIN_EMAIL=sessions-ai
ADMIN_PASSWORD=123456
ADMIN_NAME=sessions-ai

LOG_LEVEL=info
OPENROUTER_MODELS_URL=https://openrouter.ai/api/v1/models
