ARG NODE_IMAGE=node:22-alpine

# ---------- Stage 1: deps ----------
FROM ${NODE_IMAGE} AS deps
WORKDIR /repo

# Enable pnpm via Corepack
RUN corepack enable

# Copy workspace manifests first to maximise layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY apps/agent/package.json ./apps/agent/
COPY packages/shared/package.json ./packages/shared/

RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile

# ---------- Stage 2: builder ----------
FROM ${NODE_IMAGE} AS builder
WORKDIR /repo
RUN corepack enable

COPY --from=deps /repo/node_modules ./node_modules
COPY --from=deps /repo/apps/web/node_modules ./apps/web/node_modules
COPY --from=deps /repo/apps/agent/node_modules ./apps/agent/node_modules
COPY --from=deps /repo/packages/shared/node_modules ./packages/shared/node_modules

# Source
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig*.json ./
COPY packages ./packages
COPY apps/web ./apps/web

ENV NEXT_TELEMETRY_DISABLED=1
RUN pnpm --filter @sessions-ai/web build

# ---------- Stage 3: runner ----------
FROM ${NODE_IMAGE} AS runner
WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1 \
    PORT=23712 \
    HOSTNAME=0.0.0.0

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid 1001 nextjs

# Standalone output bundles only what next actually uses.
# `outputFileTracingRoot` is set to the monorepo root, so the standalone
# tree mirrors that layout under `.next/standalone/`.
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/public ./apps/web/public

# Migrations + drizzle config so the entrypoint can run schema migrations
COPY --from=builder --chown=nextjs:nodejs /repo/apps/web/drizzle ./apps/web/drizzle

USER nextjs
EXPOSE 23712

# Run via the standalone server.js generated by Next.js
WORKDIR /app/apps/web
CMD ["node", "server.js"]
